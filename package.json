{
  "name": "shop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "db:schema": "tsx prisma/scripts/build-schema.ts",
    "db:generate": "npm run db:schema && prisma generate",
    "db:push": "npm run db:schema && prisma db push",
    "db:migrate": "npm run db:schema && prisma migrate dev",
    "db:studio": "npm run db:schema && prisma studio",
    "db:seed": "npm run db:schema && prisma db seed"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "ethers": "^6.13.0",
    "jose": "^5.9.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
